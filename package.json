{
  "name": "audiobook-cleaner-lab-web",
  "version": "0.1.0",
  "private": true,
  "description": "audiobook-cleaner-lab 前端 — React + Vite + TypeScript Review MVP",
  "scripts": {
    "dev": "cd apps/web && npm run dev",
    "build": "cd apps/web && npm run build",
    "preview": "cd apps/web && npm run preview",
    "test": "cd apps/web && npm run test",
    "agent:check": "npm run build && npm run test",
    "agent:advance": "python3 scripts/auto_advance.py",
    "check:mcp": "node scripts/check_mcp_config.js",
    "check:stitch": "node scripts/check_stitch_config.js",
    "check:cursor-mcp": "bash scripts/check_cursor_mcp_status.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.3.5",
    "@modelcontextprotocol/sdk": "^1.25.2"
  }
}
