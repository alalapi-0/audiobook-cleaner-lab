{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audiobook-cleaner-lab/schemas/agent_round_report.schema.json",
  "title": "AgentRoundReport",
  "type": "object",
  "required": [
    "round_id",
    "timestamp",
    "agent",
    "agent_surface",
    "mode",
    "goal",
    "gate_status"
  ],
  "properties": {
    "round_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent": { "type": "string" },
    "agent_surface": { "type": "string", "enum": ["cursor", "codex", "other"] },
    "mode": {
      "type": "string",
      "enum": ["audit", "plan", "implement", "test", "fix", "review", "tool-probe"]
    },
    "goal": { "type": "string" },
    "scope": { "type": "array", "items": { "type": "string" } },
    "repo_status_before": { "type": "string" },
    "tool_probe_status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "not_run"]
    },
    "tools_available": { "type": "array", "items": { "type": "string" } },
    "tools_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "purpose"],
        "properties": {
          "tool": { "type": "string" },
          "purpose": { "type": "string" },
          "result": { "type": "string" },
          "fallback_used": { "type": "boolean" }
        }
      }
    },
    "tools_not_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "reason"],
        "properties": {
          "tool": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "web_research": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "source_type": { "type": "string" },
          "finding": { "type": "string" },
          "encoded_into_repo": { "type": "string" }
        }
      }
    },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "commands_run": { "type": "array", "items": { "type": "string" } },
    "test_results": { "type": "array", "items": { "type": "string" } },
    "issues_found": { "type": "array", "items": { "type": "string" } },
    "issues_fixed": { "type": "array", "items": { "type": "string" } },
    "remaining_issues": { "type": "array", "items": { "type": "string" } },
    "severity_summary": {
      "type": "object",
      "properties": {
        "p0": { "type": "integer" },
        "p1": { "type": "integer" },
        "p2": { "type": "integer" },
        "p3": { "type": "integer" }
      }
    },
    "gate_status": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "not_run"]
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "next_recommended_round": { "type": "string" },
    "human_decisions_required": { "type": "array", "items": { "type": "string" } }
  }
}
