# LLM 真实 API 配置示例（复制为 .env 后填入密钥，勿提交 .env）

# OpenAI 或兼容端点 API Key（任选其一）
LLM_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# 可选：自定义端点（OpenRouter / 本地 vLLM / Ollama 等）
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 可选：请求超时（秒）
# LLM_TIMEOUT_SEC=120

# Google Stitch UI 设计 MCP（复制后填入，勿提交 .env）
STITCH_API_KEY=your_stitch_api_key_here
