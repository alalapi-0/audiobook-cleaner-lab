# 环境变量模板 — 复制为 .env 后填入密钥，勿提交 .env

# ── GitHub MCP ──────────────────────────────────
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Stitch MCP ──────────────────────────────────
STITCH_API_KEY=

# ── LLM 真实 API（可选，业务测试用）──────────────
LLM_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# 可选：自定义端点（OpenRouter / 本地 vLLM / Ollama 等）
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 可选：请求超时（秒）
# LLM_TIMEOUT_SEC=120
